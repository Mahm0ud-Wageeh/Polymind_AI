APP_NAME=Polymind
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ------------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=polymind
DB_USERNAME=polymind
DB_PASSWORD=secret

# ------------------------------------------------------------------
# Cache / Queue / Session (Redis)
# ------------------------------------------------------------------
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ------------------------------------------------------------------
# Sanctum / CORS (SPA auth)
# ------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:5173,127.0.0.1:3000
SESSION_DOMAIN=localhost

# ------------------------------------------------------------------
# Filesystem (local | s3)
# ------------------------------------------------------------------
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ------------------------------------------------------------------
# Mail
# ------------------------------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@polymind.ai"
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------------------------------
# AI Providers  (leave blank to disable a provider)
# ------------------------------------------------------------------
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-4o-mini

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1

OLLAMA_BASE_URL=http://localhost:11434/v1

# ------------------------------------------------------------------
# Tools / MCP servers (optional)
# ------------------------------------------------------------------
MCP_GITHUB_URL=
MCP_SLACK_URL=

# ------------------------------------------------------------------
# Billing (Stripe)
# ------------------------------------------------------------------
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
BILLING_CURRENCY=USD

# ------------------------------------------------------------------
# OAuth (Socialite)
# ------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/github/callback
